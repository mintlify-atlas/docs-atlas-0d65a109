  "keyFeatures": [
    "ACID transactions with MVCC snapshot isolation",
    "B-tree storage engine with copy-on-write",
    "Write-ahead logging (WAL) for durability",
    "Full-text search with TF-IDF scoring",
    "Query language with operators and dot notation",
    "Aggregation pipeline with group, match, sort stages",
    "JSON Schema validation",
    "Change streams for real-time notifications",
    "Bulk operations for high-throughput writes",
    "Multi-language bindings (Rust, Go, Python, JavaScript)",
    "CLI with interactive REPL",
    "Web UI with REST API"
  ],
